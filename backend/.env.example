NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@db:5432/galeria_recrear
FRONTEND_ORIGIN=http://localhost:4321
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_DAYS=14
MEDIA_STORAGE=local
LOCAL_MEDIA_DIR=/tmp/galeria-recrear/media
UPLOAD_TEMP_DIR=/tmp/galeria-recrear/uploads
MAX_FILE_SIZE_MB=500
DRIVE_ROOT_FOLDER_ID=
# Elegí un único modo de credenciales. Para Shared Drive: cuenta de servicio.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
# Para carpeta de My Drive (cuenta personal o usuario técnico): OAuth 2.0.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
INITIAL_ADMIN_EMAIL=admin@recrear.local
INITIAL_ADMIN_PASSWORD=change-me-now

